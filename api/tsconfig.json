{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // Basic Options
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",

    // Strict Type-Checking Options
    "strict": true,

    // Additional Checks
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Type Definitions
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
