# Production environment variables template.
# Copy this file to .env on your server and fill in real values.
# NEVER commit the .env file with real secrets to git.

# --- PostgreSQL ---
POSTGRES_USER=workhelper
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=workhelper

# --- Next.js (web) ---
# Set to your API subdomain
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-north-1
S3_BUCKET_NAME=wh-docs

# --- JWT (add to api if needed) ---
# JWT_SECRET=change-me-strong-secret
